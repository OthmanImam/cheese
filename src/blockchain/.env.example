# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cheese_wallet
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# ── Blockchain / Smart Contract ───────────────────────────────────────────────
# JSON-RPC endpoint for your EVM chain
# Polygon: https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# Base:    https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# BSC:     https://bsc-dataseed.binance.org
BLOCKCHAIN_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Platform custodial wallet — holds all user funds in the custodial model.
# NEVER commit the private key. Use a secrets manager (AWS Secrets Manager,
# HashiCorp Vault, GCP Secret Manager) in production.
PLATFORM_WALLET_PRIVATE_KEY=0x_REPLACE_WITH_ACTUAL_PRIVATE_KEY
PLATFORM_WALLET_ADDRESS=0x_REPLACE_WITH_PLATFORM_EOA_ADDRESS

# Deployed address of the Cheese Wallet smart contract on your chosen chain.
WALLET_CONTRACT_ADDRESS=0x_REPLACE_WITH_CONTRACT_ADDRESS

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
